# Resend API key for quote inquiry email delivery
# Get yours at https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender on your Resend domain (e.g. quotes@nitroplus.ae)
# Must be on a domain you've verified with Resend.
RESEND_FROM_EMAIL=

# Email address that receives quote inquiries (the inbox you read)
INQUIRY_EMAIL=

# Email address that receives job applications. Same constraints as INQUIRY_EMAIL:
# until your domain is verified in Resend, this must be the Resend account email.
# Defaults to INQUIRY_EMAIL if unset.
CAREERS_EMAIL=

# WhatsApp business number (with country code, no + or spaces)
# Example: 971501234567
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Site URL — used for canonical links and sitemap (no trailing slash)
# Example: https://nitroplus.ae
NEXT_PUBLIC_SITE_URL=http://localhost:3000